{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(bash /Users/andychan/.claude/skills/agent-audit/scripts/run-evals.sh *)",
      "Bash(bash /Users/andychan/.claude/scripts/plan-tune-preflight.sh *)",
      "Edit(/.claude/skills/improve/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/changelog-gate.py",
            "statusMessage": "Checking CHANGELOG.md…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport sys, json\nd = json.load(sys.stdin)\ncmd = d.get('tool_input', {}).get('command', '')\nif any(x in cmd for x in ['git add', 'git stage']):\n    print('Changes staged — invoke /msg-commit to generate a commit message.')\n\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
